# AdGuard Home Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Admin user credentials (set via web UI after first deployment)
# Default: http://<server-ip>:3000
# The admin user password hash in AdGuardHome.yaml is intentionally blanked.
# After deploying, access the web UI and create your admin account.

# Timezone
TZ=Asia/Jakarta
