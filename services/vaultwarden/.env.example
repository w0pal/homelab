# Vaultwarden Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Domain for Vaultwarden (required for HTTPS, passkeys, etc.)
DOMAIN=https://lab.tailf2af36.ts.net

# Enable WebSocket for live sync across devices
WEBSOCKET_ENABLED=true

# Allow new user signups (set to false after initial setup)
SIGNUPS_ALLOWED=true

# Admin token for /admin panel (generate with: openssl rand -base64 32)
# Set this in GitHub Secrets as VAULTWARDEN_ADMIN_TOKEN
ADMIN_TOKEN=your_admin_token_here

# Logging
LOG_LEVEL=info
EXTENDED_LOGGING=true

# Optional: Disable 2FA for specific users (comma-separated emails)
# 2FA_VERIFICATION=False

# Optional: SMTP for email verification (configure if needed)
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vaultwarden@example.com
# SMTP_PORT=587
# SMTP_SSL=true
# SMTP_USERNAME=user
# SMTP_PASSWORD=pass