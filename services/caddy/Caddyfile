# Caddy reverse proxy for local LAN HTTPS
# Uses the same cert Tailscale generated for lab.tailf2af36.ts.net

{
    admin off
    # No auto HTTPS - we provide our own cert
    auto_https off
}

lab.tailf2af36.ts.net {
    bind 192.168.0.206
    tls /etc/caddy/certs/lab.tailf2af36.ts.net.crt /etc/caddy/certs/lab.tailf2af36.ts.net.key

    reverse_proxy http://127.0.0.1:8080 {
        header_up Host {http.request.host}
        header_up X-Real-IP {http.request.remote.host}
        header_up X-Forwarded-For {http.request.remote.host}
        header_up X-Forwarded-Proto https
    }

    # WebSocket support for Vaultwarden live sync
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket http://127.0.0.1:8080 {
        header_up Host {http.request.host}
        header_up Upgrade {http.request.header.Upgrade}
        header_up Connection {http.request.header.Connection}
    }
}

cockpit.lab {
    bind 192.168.0.206
    tls /etc/caddy/certs/lab.tailf2af36.ts.net.crt /etc/caddy/certs/lab.tailf2af36.ts.net.key

    reverse_proxy http://127.0.0.1:9090
}