# Nginx Proxy Manager Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Admin UI: http://<server-ip>:81
# Default credentials (set on first run):
#   Email:    admin@example.com
#   Password: set during initial setup wizard
#
# These are NOT stored in any config file.
# If you need to reset: docker compose down && rm -rf data/database.sqlite && docker compose up -d

# Timezone
TZ=Asia/Jakarta
